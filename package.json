{
  "name": "yc_directory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typegen": "sanity schema extract --path=./sanity/extract.json && sanity typegen generate"
  },
  "packageManager": "npm@11.5.1",
